schema spec_finder {
    document spec_finder {
        field doc_id type string {
            indexing: summary | attribute
            match: exact
        }
        field doc_type type string {
            indexing: summary | attribute
            match: exact
        }
        field content_kind type string {
            indexing: summary | attribute
            match: exact
        }
        field spec_no type string {
            indexing: summary | attribute
            match: exact
        }
        field spec_title type string {
            indexing: index | summary
            index: enable-bm25
        }
        field release type string {
            indexing: summary | attribute
            match: exact
        }
        field release_data type string {
            indexing: summary | attribute
            match: exact
        }
        field series type string {
            indexing: summary | attribute
            match: exact
        }
        field ts_or_tr type string {
            indexing: summary | attribute
            match: exact
        }
        field stage_hint type string {
            indexing: index | summary | attribute
            index: enable-bm25
        }
        field clause_id type string {
            indexing: summary | attribute
            match: exact
        }
        field clause_title type string {
            indexing: index | summary
            index: enable-bm25
        }
        field clause_path type array<string> {
            indexing: summary | attribute
        }
        field parent_clause_id type string {
            indexing: summary | attribute
            match: exact
        }
        field text type string {
            indexing: index | summary
            index: enable-bm25
        }
        field summary_text type string {
            indexing: index | summary
        }
        field retrieval_weight type double {
            indexing: summary | attribute
        }
        field keywords type array<string> {
            indexing: index | summary | attribute
        }
        field anchor_terms type array<string> {
            indexing: index | summary | attribute
        }
        field ie_names type array<string> {
            indexing: index | summary | attribute
        }
        field message_names type array<string> {
            indexing: index | summary | attribute
        }
        field procedure_names type array<string> {
            indexing: index | summary | attribute
        }
        field table_headers type array<string> {
            indexing: index | summary
        }
        field acronyms type array<string> {
            indexing: index | summary | attribute
        }
        field camel_case_identifiers type array<string> {
            indexing: index | summary | attribute
        }
        field referenced_specs type array<string> {
            indexing: summary | attribute
        }
        field referenced_clauses type array<string> {
            indexing: summary | attribute
        }
        field source_file type string {
            indexing: summary | attribute
        }
        field table_title type string {
            indexing: index | summary
            index: enable-bm25
        }
        field order_in_source type int {
            indexing: summary | attribute
        }
        field version_tag type string {
            indexing: summary | attribute
            match: exact
        }
        field domain_hint type array<string> {
            indexing: index | summary | attribute
        }
        field embedding_text type string {
            indexing: index | summary
            index: enable-bm25
        }
        field embedding_model type string {
            indexing: summary | attribute
        }
        field embedding_dim type int {
            indexing: summary | attribute
        }
        field dense_embedding type tensor<float>(x[1024]) {
            indexing: attribute | summary
            attribute {
                distance-metric: angular
            }
        }
        field table_id type string {
            indexing: summary | attribute
            match: exact
        }
        field row_index type int {
            indexing: summary | attribute
        }
        field row_header type string {
            indexing: index | summary
            index: enable-bm25
        }
        field row_cells type array<string> {
            indexing: index | summary
        }
        field table_raw_json type string {
            indexing: summary
        }
        field table_markdown type string {
            indexing: summary
        }
        field passage_id type string {
            indexing: summary | attribute
            match: exact
        }
        field passage_index type int {
            indexing: summary | attribute
        }
        field paragraph_start_index type int {
            indexing: summary | attribute
        }
        field paragraph_end_index type int {
            indexing: summary | attribute
        }
        field entity_type type string {
            indexing: summary | attribute
        }
        field entity_name type string {
            indexing: index | summary
            index: enable-bm25
        }
        field source_doc_id type string {
            indexing: summary | attribute
            match: exact
        }
    }

    fieldset default {
        fields: spec_title, clause_title, table_title, row_header, text, embedding_text, anchor_terms, keywords, ie_names, message_names, procedure_names, entity_name, stage_hint
    }

    document-summary short {
        summary doc_id {}
        summary doc_type {}
        summary spec_no {}
        summary spec_title {}
        summary release {}
        summary release_data {}
        summary stage_hint {}
        summary clause_id {}
        summary clause_title {}
        summary table_title {}
        summary row_header {}
        summary text {}
        summary anchor_terms {}
        summary ie_names {}
        summary message_names {}
        summary procedure_names {}
        summary referenced_specs {}
        summary entity_type {}
        summary entity_name {}
        summary source_file {}
        summary retrieval_weight {}
    }

    rank-profile bm25 inherits default {
        inputs {
            query(anchor_boost) double: 1.0
            query(title_boost) double: 1.0
            query(stage_boost) double: 1.0
        }
        first-phase {
            expression: (bm25(text) * 1.0 + bm25(embedding_text) * 1.4 + bm25(clause_title) * 1.8 * query(title_boost) + bm25(table_title) * 1.3 + bm25(row_header) * 1.5 + bm25(spec_title) * 1.2 * query(title_boost) + bm25(stage_hint) * 1.1 * query(stage_boost) + bm25(anchor_terms) * 1.7 * query(anchor_boost) + bm25(ie_names) * 1.9 + bm25(message_names) * 1.9 + bm25(procedure_names) * 1.5 + bm25(entity_name) * 2.0) * attribute(retrieval_weight)
        }
        summary-features {
            bm25(text)
            bm25(embedding_text)
            bm25(clause_title)
            bm25(table_title)
            bm25(row_header)
            bm25(spec_title)
            bm25(stage_hint)
            bm25(anchor_terms)
            bm25(ie_names)
            bm25(message_names)
            bm25(procedure_names)
            bm25(entity_name)
        }
    }

    rank-profile table_focus inherits bm25 {
        first-phase {
            expression: (bm25(text) * 0.8 + bm25(embedding_text) * 1.2 + bm25(table_title) * 1.7 + bm25(row_header) * 1.9 + bm25(anchor_terms) * 1.4) * attribute(retrieval_weight)
        }
    }

    rank-profile anchor_boost inherits bm25 {
        first-phase {
            expression: (bm25(text) * 0.9 + bm25(embedding_text) * 1.2 + bm25(clause_title) * 1.8 + bm25(table_title) * 1.2 + bm25(row_header) * 1.5 + bm25(spec_title) * 1.2 + bm25(anchor_terms) * 2.3 + bm25(ie_names) * 2.0 + bm25(message_names) * 2.0 + bm25(entity_name) * 2.1 + bm25(stage_hint) * 1.2) * attribute(retrieval_weight)
        }
    }

    rank-profile hybrid inherits bm25 {
        inputs {
            query(anchor_boost) double: 1.0
            query(title_boost) double: 1.0
            query(stage_boost) double: 1.0
            query(sparse_boost) double: 1.0
            query(vector_boost) double: 1.0
            query(query_embedding) tensor<float>(x[1024])
        }
        function sparse_score() {
            expression: (bm25(text) * 0.7 + bm25(embedding_text) * 0.9 + bm25(clause_title) * 1.5 * query(title_boost) + bm25(table_title) * 1.0 * query(title_boost) + bm25(row_header) * 1.0 + bm25(spec_title) * 1.1 * query(title_boost) + bm25(stage_hint) * 1.2 * query(stage_boost) + bm25(anchor_terms) * 0.5 * query(anchor_boost) + bm25(ie_names) * 1.7 + bm25(message_names) * 1.7 + bm25(procedure_names) * 1.3 + bm25(entity_name) * 1.8) * attribute(retrieval_weight)
        }
        function dense_score() {
            expression: closeness(field, dense_embedding) * 9.0
        }
        first-phase {
            expression: sparse_score * query(sparse_boost) + dense_score * query(vector_boost)
        }
        summary-features {
            bm25(text)
            bm25(embedding_text)
            bm25(clause_title)
            bm25(table_title)
            bm25(row_header)
            bm25(spec_title)
            bm25(stage_hint)
            bm25(anchor_terms)
            bm25(ie_names)
            bm25(message_names)
            bm25(procedure_names)
            bm25(entity_name)
            closeness(field, dense_embedding)
            attribute(retrieval_weight)
        }
    }
}
